{% comment %}
Smart Header with Salla components - Fixed Version
{% endcomment %}

<header class="store-header" style="background: white; border-bottom: 1px solid #e5e7eb; position: sticky; top: 0; z-index: 1000;">
  
  <!-- Main Navigation - Simplified -->
  <div class="main-nav-container" style="background: white;">
    <div class="container" style="max-width: 1200px; margin: 0 auto; padding: 0 1rem;">
      <div class="header-content" style="display: flex; align-items: center; justify-content: space-between; height: 64px;">
        
        <!-- Logo -->
        <div class="header-logo" style="flex-shrink: 0;">
          <a href="{{ store.url }}" style="display: flex; align-items: center; text-decoration: none; color: inherit;">
            <img width="auto" height="40" src="{{ store.logo | cdn(175) }}" alt="{{ store.name }}" style="max-height: 40px;">
          </a>
        </div>

        <!-- Main Menu -->
        <div class="header-menu" style="flex: 1; display: flex; justify-content: center;">
          <nav style="display: flex; gap: 2rem;">
            <a href="/" style="color: #374151; text-decoration: none; font-weight: 500;">{{ 'home' | t | default: 'Home' }}</a>
            <a href="/about" style="color: #374151; text-decoration: none; font-weight: 500;">{{ 'about' | t | default: 'About' }}</a>
            <a href="/services" style="color: #374151; text-decoration: none; font-weight: 500;">{{ 'services' | t | default: 'Services' }}</a>
            <a href="/contact" style="color: #374151; text-decoration: none; font-weight: 500;">{{ 'contact' | t | default: 'Contact' }}</a>
          </nav>
        </div>

        <!-- Actions -->
        <div class="header-actions" style="display: flex; align-items: center; gap: 1rem;">
          <salla-user-menu avatar-only show-header show-trigger></salla-user-menu>
          <salla-cart-summary style="position: relative;">
            <i class="sicon-shopping-bag" style="font-size: 20px; color: #374151;"></i>
          </salla-cart-summary>
        </div>

      </div>
    </div>
  </div>
  
</header>

<style>
.store-header {
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
}

.header-content a:hover {
  color: #2563eb !important;
}

@media (max-width: 768px) {
  .header-menu {
    display: none !important;
  }
  
  .header-content {
    height: 56px !important;
  }
  
  .header-logo img {
    height: 32px !important;
  }
}
</style>
