{% comment %}
Header section with three different styles based on theme settings
{% endcomment %}

<header class="{{ settings.header_style }}-header">
    <nav class="nav">
        <!-- Logo -->
        <a href="/" class="nav-logo">
            {{ store.name }}
        </a>
        
        <!-- Navigation Menu -->
        <ul class="nav-menu">
            <li><a href="/">{{ 'home' | t }}</a></li>
            <li><a href="/about">{{ 'about' | t }}</a></li>
            <li><a href="/services">{{ 'services' | t }}</a></li>
            <li><a href="/booking">{{ 'booking' | t }}</a></li>
            <li><a href="/contact">{{ 'contact' | t }}</a></li>
        </ul>
        
        <!-- Mobile Menu Toggle -->
        <button class="mobile-menu-toggle">☰</button>
    </nav>
</header>
