{
    "name": {
        "ar": "ثيم المدربين",
        "en": "Coach Theme"
    },
    "version": "1.1.0",
    "author": "Theme Developer",
    "description": {
        "ar": "ثيم احترافي مخصص للمدربين والمعلمين",
        "en": "Professional theme for coaches and trainers"
    },
    "settings": [
        {
            "id": "header_style",
            "type": "select",
            "label": {
                "ar": "نمط الهيدر",
                "en": "Header Style"
            },
            "options": [
                {"label": {"ar": "كلاسيكي", "en": "Classic"},  "value": "classic"},
                {"label": {"ar": "عصري",    "en": "Modern"},   "value": "modern"},
                {"label": {"ar": "بسيط",    "en": "Minimal"},  "value": "minimal"}
            ],
            "default": "classic"
        },
        {
            "id": "dark_mode",
            "type": "checkbox",
            "label": {
                "ar": "تفعيل الوضع الليلي",
                "en": "Enable Dark Mode"
            },
            "default": false
        },
        {
            "id": "coach_booking_form",
            "type": "checkbox",
            "label": {
                "ar": "عرض نموذج حجز الجلسات",
                "en": "Show Booking Form"
            },
            "default": true
        },
        {
            "id": "testimonials_display",
            "type": "select",
            "label": {
                "ar": "طريقة عرض آراء العملاء",
                "en": "Testimonials Display"
            },
            "options": [
                {"label": {"ar": "شريط متحرك", "en": "Carousel"}, "value": "carousel"},
                {"label": {"ar": "شبكة",       "en": "Grid"},     "value": "grid"},
                {"label": {"ar": "قائمة",      "en": "List"},     "value": "list"}
            ],
            "default": "carousel"
        },
        {
            "id": "infinite_slider",
            "type": "checkbox",
            "label": {
                "ar": "عرض شريط الصور المتحرك",
                "en": "Show Infinite Image Slider"
            },
            "default": false
        },
        {
            "id": "before_after_slider",
            "type": "checkbox",
            "label": {
                "ar": "عرض مقارن قبل وبعد",
                "en": "Show Before/After Comparison Slider"
            },
            "default": false
        },
        {
            "id": "hero_background_image",
            "type": "image",
            "label": {
                "ar": "صورة خلفية الهيرو",
                "en": "Hero Background Image"
            },
            "default": ""
        },
        {
            "id": "subscribers_count",
            "type": "text",
            "label": {
                "ar": "عدد المشتركين",
                "en": "Subscribers Count"
            },
            "default": "500+",
            "placeholder": {
                "ar": "أدخل العدد",
                "en": "Enter number"
            }
        },
        {
            "id": "experience_years",
            "type": "text",
            "label": {
                "ar": "سنوات الخبرة",
                "en": "Years of Experience"
            },
            "default": "10+",
            "placeholder": {
                "ar": "أدخل السنوات",
                "en": "Enter years"
            }
        },
        {
            "id": "smart_survey",
            "type": "checkbox",
            "label": {
                "ar": "تفعيل نظام الاستبيان الذكي",
                "en": "Enable Smart Survey System"
            },
            "default": true
        },
        {
            "id": "survey_questions",
            "type": "textarea",
            "label": {
                "ar": "أسئلة الاستبيان (سطر واحد للسؤال)",
                "en": "Survey Questions (one per line)"
            },
            "default": "ما هو هدفك الرئيسي؟\nما هو مستواك الحالي؟\nما هي أكبر تحدي تواجهه؟\nكم ساعة في الأسبوع يمكنك التدريب؟",
            "placeholder": {
                "ar": "أدخل الأسئلة هنا",
                "en": "Enter questions here"
            }
        },
        {
            "id": "cart_button_text",
            "type": "text",
            "label": {
                "ar": "نص زر السلة",
                "en": "Cart Button Text"
            },
            "default": "احجز باقتك الآن",
            "placeholder": {
                "ar": "أدخل النص",
                "en": "Enter button text"
            }
        },
        {
            "id": "show_survey",
            "type": "checkbox",
            "label": {
                "ar": "عرض الاستبيان في صفحة المنتج",
                "en": "Show Survey on Product Page"
            },
            "default": true
        }
    ],
    "assets": {
        "css": [
            "assets/css/theme.css"
        ],
        "js": [
            "assets/js/theme.js"
        ]
    }
}
