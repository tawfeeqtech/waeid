{% block scripts %}
<script>
// Multi-step form functionality
document.addEventListener('DOMContentLoaded', function() {
    const form = document.querySelector('.multi-step-form');
    if (!form) return;
    
    const steps = form.querySelectorAll('.form-step');
    const stepIndicators = form.querySelectorAll('.step');
    const progressFill = form.querySelector('.progress-fill');
    const totalSteps = steps.length;
    let currentStep = 0;
    
    function showStep(stepIndex) {
        steps.forEach((step, index) => {
            step.classList.toggle('active', index === stepIndex);
        });
        
        stepIndicators.forEach((indicator, index) => {
            indicator.classList.toggle('active', index === stepIndex);
            indicator.classList.toggle('completed', index < stepIndex);
        });
        
        const progress = ((stepIndex + 1) / totalSteps) * 100;
        progressFill.style.width = progress + '%';
        
        // Scroll to top of form
        form.scrollIntoView({ behavior: 'smooth', block: 'start' });
    }
    
    // Next step buttons
    form.querySelectorAll('.next-step').forEach(button => {
        button.addEventListener('click', () => {
            const currentStepElement = steps[currentStep];
            const requiredFields = currentStepElement.querySelectorAll('[required]');
            let isValid = true;
            
            requiredFields.forEach(field => {
                if (!field.value || (field.type === 'radio' && !form.querySelector(`input[name="${field.name}"]:checked`))) {
                    isValid = false;
                }
            });
            
            if (isValid && currentStep < totalSteps - 1) {
                currentStep++;
                showStep(currentStep);
            }
        });
    });
    
    // Previous step buttons
    form.querySelectorAll('.prev-step').forEach(button => {
        button.addEventListener('click', () => {
            if (currentStep > 0) {
                currentStep--;
                showStep(currentStep);
            }
        });
    });
    
    // Form submission
    form.addEventListener('submit', (e) => {
        e.preventDefault();
        
        // Collect form data
        const formData = new FormData(form);
        const data = Object.fromEntries(formData);
        
        // Track form submission
        if (window.FunnelAnalytics) {
            window.FunnelAnalytics.trackEvent('form_submit', {
                formType: 'pre-qualification',
                data: data
            });
        }
        
        // Show success message or redirect
        alert('{{ user.language.code == "ar" ? "شكراً لك! سنقوم بالتواصل معك قريباً." : "Thank you! We will contact you soon." }');
        
        // Reset form
        form.reset();
        currentStep = 0;
        showStep(currentStep);
    });
});

// FAQ functionality
document.addEventListener('DOMContentLoaded', function() {
    const faqQuestions = document.querySelectorAll('.faq-question');
    
    faqQuestions.forEach(question => {
        question.addEventListener('click', () => {
            const faqItem = question.closest('.faq-item');
            const answer = faqItem.querySelector('.faq-answer');
            const isActive = question.classList.contains('active');
            
            // Close all other FAQs
            document.querySelectorAll('.faq-question').forEach(q => {
                q.classList.remove('active');
                q.closest('.faq-item').querySelector('.faq-answer').classList.remove('open');
            });
            
            // Toggle current FAQ
            if (!isActive) {
                question.classList.add('active');
                answer.classList.add('open');
            }
        });
    });
});
</script>
{% endblock %}
