{#
 | Hero System v2.0 — Dynamic Combinatorial
 | =========================================
 | NO fixed variants. Hero composes from 5 independent axes:
 |
 |   layout_mode  : stacked | split | overlay-card | minimal | banded | full-bleed
 |   media_type   : image | video | gradient | pattern | none
 |   alignment    : start | center | end       (logical — RTL safe)
 |   emphasis     : text | media | stats | balanced
 |   cta_style    : solid | outline | ghost | pill | square | dual-pill
 |
 | Plus continuous overrides: text_color, bg_color, overlay_color,
 | overlay_opacity (0-100), min_height, container_width.
 |
 | All styling driven by data-* attributes + scoped CSS variables.
 | Zero {% if variant == 'x' %} branches.
 #}

{# ── 1) Pull axes from `component.*` (Salla namespace) ─────────── #}
{% macro pick(raw, fallback) %}
  {%- if raw is iterable and raw|length > 0 -%}
    {%- set f = raw|first -%}
    {%- if f is iterable -%}{{ attribute(f, 'value') | default(fallback) }}
    {%- else -%}{{ f | default(fallback) }}
    {%- endif -%}
  {%- elseif raw is not empty -%}{{ raw }}
  {%- else -%}{{ fallback }}{%- endif -%}
{% endmacro %}

{% import _self as h %}

{% set layout    = h.pick(component.layout_mode,  'stacked')   | trim %}
{% set media     = h.pick(component.media_type,   'image')     | trim %}
{% set align     = h.pick(component.alignment,    'center')    | trim %}
{% set emphasis  = h.pick(component.emphasis,     'balanced')  | trim %}
{% set cta_sty   = h.pick(component.cta_style,    'solid')     | trim %}
{% set min_h_key = h.pick(component.min_height,   'large')     | trim %}
{% set width_key = h.pick(component.container_width, 'contained') | trim %}

{# ── 2) Content fields ─────────────────────────────────────────── #}
{% set badge       = component.badge_text   %}
{% set title       = component.title        %}
{% set subtitle    = component.subtitle     %}
{% set cta_txt     = component.cta_text     %}
{% set cta_url     = component.cta_url      %}
{% set sec_txt     = component.sec_cta_text %}
{% set sec_url     = component.sec_cta_url  %}
{% set image       = component.image        %}
{% set video_id    = component.video_id     %}
{% set show_stats  = component.show_stats   %}
{% set stats       = component.stats | default([]) %}

{# ── 3) Color & overlay overrides ──────────────────────────────── #}
{% set c_text    = component.text_color    | default('') %}
{% set c_bg      = component.bg_color      | default('') %}
{% set c_over    = component.overlay_color | default('#000000') %}
{% set c_alpha   = (component.overlay_opacity | default(40)) / 100 %}

{# ── 4) Height & width tables ──────────────────────────────────── #}
{% set h_map = {
  'auto':   'auto',
  'small':  '420px',
  'medium': '560px',
  'large':  '720px',
  'screen': '100vh'
} %}
{% set w_map = {
  'narrow':    '720px',
  'contained': '1200px',
  'wide':      '1440px',
  'full':      '100%'
} %}
{% set v_min_h = h_map[min_h_key] | default('720px') %}
{% set v_width = w_map[width_key] | default('1200px') %}

{# ── 5) Style payload — scoped CSS vars ────────────────────────── #}
{% set style_payload %}
  --hero-min-h: {{ v_min_h }};
  --hero-max-w: {{ v_width }};
  --hero-overlay: {{ c_over }};
  --hero-overlay-alpha: {{ c_alpha }};
  {% if c_text %}--hero-text: {{ c_text }};{% endif %}
  {% if c_bg %}--hero-bg: {{ c_bg }};{% endif %}
{% endset %}

{# ══════════════════════════════════════════════════════════════════
   ONE section, all axes encoded as data-* — CSS does the variant work.
   ══════════════════════════════════════════════════════════════════ #}
<section
  class="hero"
  data-layout="{{ layout }}"
  data-media="{{ media }}"
  data-align="{{ align }}"
  data-emphasis="{{ emphasis }}"
  data-cta="{{ cta_sty }}"
  style="{{ style_payload | spaceless }}"
  aria-label="{{ title | default('Hero') }}"
  {% if media == 'video' and video_id %}x-data="{ vRdy: false }" x-init="$nextTick(()=>vRdy=true)"{% endif %}
>

  {# ── Media layer (only renders when relevant) ── #}
  {% if media == 'image' and image %}
    <img class="hero__bg"
         src="{{ image | cdn(1920) }}"
         alt=""
         role="presentation"
         loading="eager"
         fetchpriority="high"
         decoding="async">

  {% elseif media == 'video' and video_id %}
    <img class="hero__bg" src="{{ image | cdn(1920) }}" alt="" loading="eager" fetchpriority="high">
    <template x-if="vRdy">
      <iframe class="hero__video"
              src="https://www.youtube.com/embed/{{ video_id }}?autoplay=1&mute=1&loop=1&controls=0&playlist={{ video_id }}&playsinline=1"
              frameborder="0" allow="autoplay; encrypted-media" tabindex="-1" aria-hidden="true"></iframe>
    </template>

  {% elseif media == 'gradient' %}
    <div class="hero__bg hero__bg--gradient" aria-hidden="true"></div>

  {% elseif media == 'pattern' %}
    <div class="hero__bg hero__bg--pattern" aria-hidden="true"></div>
  {% endif %}

  {# ── Overlay (skipped if alpha=0 or layout=overlay-card to keep card crisp) ── #}
  {% if c_alpha > 0 and layout != 'overlay-card' and media != 'none' %}
    <div class="hero__overlay" aria-hidden="true"></div>
  {% endif %}

  {# ── Content shell ── #}
  <div class="hero__shell">
    <div class="hero__content {{ layout == 'overlay-card' ? 'hero__content--card' : '' }}">

      {% if badge %}
        <span class="hero__badge">
          <span class="hero__badge-dot" aria-hidden="true"></span>{{ badge }}
        </span>
      {% endif %}

      {% if title %}
        <h1 class="hero__title">{{ title }}</h1>
      {% endif %}

      {% if subtitle %}
        <p class="hero__subtitle">{{ subtitle }}</p>
      {% endif %}

      {% if show_stats and stats|length > 0 %}
        <div class="hero__stats" role="list">
          {% for s in stats %}
            <div class="hero__stat" role="listitem">
              <span class="hero__stat-num">{{ s.stat_number }}</span>
              <span class="hero__stat-lbl">{{ s.stat_label }}</span>
            </div>
          {% endfor %}
        </div>
      {% endif %}

      {% if cta_txt or sec_txt %}
        <div class="hero__ctas">
          {% if cta_txt %}
            <a class="hero__cta hero__cta--primary" href="{{ cta_url | default('#') }}">
              <span>{{ cta_txt }}</span>
              <i class="sicon-arrow-left rtl:inline-block ltr:hidden text-sm" aria-hidden="true"></i>
              <i class="sicon-arrow-right ltr:inline-block rtl:hidden text-sm" aria-hidden="true"></i>
            </a>
          {% endif %}
          {% if sec_txt %}
            <a class="hero__cta hero__cta--secondary" href="{{ sec_url | default('#') }}">
              <span>{{ sec_txt }}</span>
            </a>
          {% endif %}
        </div>
      {% endif %}

    </div>{# /content #}

    {# Side media slot — used only by layout="split" or "full-bleed" with image #}
    {% if (layout == 'split' or layout == 'full-bleed') and media == 'image' and image %}
      <div class="hero__side-media" aria-hidden="true">
        <img src="{{ image | cdn(960) }}" alt="" loading="eager" fetchpriority="high" decoding="async">
      </div>
    {% endif %}
  </div>{# /shell #}
</section>
