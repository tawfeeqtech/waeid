{#
 | Header Slot Renderer — included by header.twig
 | ===============================================
 | Using {% include %} instead of a macro so that ALL Salla
 | template variables (store, user, theme, is_page(), ...) are
 | available in full scope.
 |
 | Variables received via `with { slot, cta_text, cta_url }`:
 |   slot      string  logo|menu|search|cta_button|social|actions|empty
 |   cta_text  string
 |   cta_url   string
 #}

{# ── Logo ───────────────────────────────────────────────────── #}
{% if slot == 'logo' %}
  <a class="header-logo" href="{{ store.url }}" aria-label="{{ store.name }}">
    <img
      fetchpriority="high"
      width="auto"
      height="48"
      loading="eager"
      src="{{ store.logo | cdn(175) }}"
      alt="{{ store.name }} logo"
    >
    {% if is_page('index') %}
      <h1 class="sr-only">{{ store.name }}</h1>
    {% else %}
      <h2 class="sr-only">{{ store.name }}</h2>
    {% endif %}
  </a>

{# ── Main Menu ───────────────────────────────────────────────── #}
{% elseif slot == 'menu' %}
  <custom-main-menu></custom-main-menu>

{# ── Search ──────────────────────────────────────────────────── #}
{% elseif slot == 'search' %}
  <div class="header-slot-search">
    <salla-search inline oval height="36"></salla-search>
  </div>

{# ── CTA Button ──────────────────────────────────────────────── #}
{% elseif slot == 'cta_button' %}
  <a href="{{ cta_url }}" class="header-cta-btn">
    <span>{{ cta_text }}</span>
    <i class="sicon-arrow-left rtl:inline-block ltr:hidden text-sm" aria-hidden="true"></i>
    <i class="sicon-arrow-right ltr:inline-block rtl:hidden text-sm" aria-hidden="true"></i>
  </a>

{# ── Social / Contacts ───────────────────────────────────────── #}
{% elseif slot == 'social' %}
  <salla-contacts is-header></salla-contacts>

{# ── User Actions (Cart + User Menu) ────────────────────────── #}
{% elseif slot == 'actions' %}
  <div class="header-actions">
    <salla-user-menu avatar-only show-header show-trigger></salla-user-menu>
    <salla-cart-summary class="rtl:me-2 ltr:ms-2">
      <i slot="icon" class="header-btn__icon icon sicon-shopping-bag"></i>
    </salla-cart-summary>
  </div>

{# ── Empty — renders nothing, flex-1 still holds the space ───── #}
{% endif %}
