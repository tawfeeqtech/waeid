{#
 | Smart Header Matrix v1.3  — Production
 | ========================================
 | Architecture: {% include %} (NOT macro) keeps full Salla scope.
 | Slot file: components/header/_slot.twig
 |
 | CRITICAL: Salla `items/dropdown-list` returns Array of Objects:
 |   [{ label: "...", value: "logo", key: "..." }]
 | We MUST extract `.value` from the first element.
 |
 | NOTE: Twig {% set %} INSIDE {% for %} does NOT persist to outer
 | scope. We use direct |first + attribute() instead — DO NOT
 | switch to a for-loop or slots will silently fall back to defaults.
 #}

{# ══════════════════════════════════════════════════════════════
   1) Raw values from Salla settings
   ══════════════════════════════════════════════════════════════ #}
{% set _raw_start  = theme.settings.get('header_slot_start') %}
{% set _raw_center = theme.settings.get('header_slot_center') %}
{% set _raw_end    = theme.settings.get('header_slot_end') %}

{# ══════════════════════════════════════════════════════════════
   2) Robust extraction — handles ALL possible Salla return shapes:
      • [{value:"logo",...}]  (normal dropdown-list)
      • "logo"                (legacy / flattened)
      • [] or null            (unset)
      • [{...}, {...}]        (multi-select — take first)
   Set in if/else (NOT for) so scope persists to outer template.
   ══════════════════════════════════════════════════════════════ #}
{% set slot_start  = 'logo' %}
{% set slot_center = 'menu' %}
{% set slot_end    = 'actions' %}

{% if _raw_start is iterable and _raw_start|length > 0 %}
  {% set _f = _raw_start|first %}
  {% set slot_start = (_f is iterable) ? (attribute(_f, 'value') | default('logo')) : (_f | default('logo')) %}
{% elseif _raw_start is not empty %}
  {% set slot_start = _raw_start %}
{% endif %}

{% if _raw_center is iterable and _raw_center|length > 0 %}
  {% set _f = _raw_center|first %}
  {% set slot_center = (_f is iterable) ? (attribute(_f, 'value') | default('menu')) : (_f | default('menu')) %}
{% elseif _raw_center is not empty %}
  {% set slot_center = _raw_center %}
{% endif %}

{% if _raw_end is iterable and _raw_end|length > 0 %}
  {% set _f = _raw_end|first %}
  {% set slot_end = (_f is iterable) ? (attribute(_f, 'value') | default('actions')) : (_f | default('actions')) %}
{% elseif _raw_end is not empty %}
  {% set slot_end = _raw_end %}
{% endif %}

{# ══════════════════════════════════════════════════════════════
   3) Behavior settings + CTA bundle for slot includes
   ══════════════════════════════════════════════════════════════ #}
{% set header_is_transparent = theme.settings.get('header_is_transparent') | default(false) %}
{% set header_show_topbar    = theme.settings.get('header_show_topbar')    | default(true) %}
{% set topnav_is_dark        = theme.settings.get('topnav_is_dark')        | default(false) %}
{% set important_links       = theme.settings.get('important_links')       | default(false) %}
{% set header_cta_text       = theme.settings.get('header_cta_text')       | default('احجز الآن') %}
{% set header_cta_url        = theme.settings.get('header_cta_url')        | default(store.url) %}

{% set _slot_vars = { cta_text: header_cta_text, cta_url: header_cta_url } %}

{# ══════════════════════════════════════════════════════════════
   4) DEBUG — visible in Page Source (View → Source). Remove in prod.
   ══════════════════════════════════════════════════════════════ #}
<!-- HEADER DEBUG ▼ -->
<!-- raw_start  type={{ _raw_start  is iterable ? 'array' : 'scalar' }} json={{ _raw_start  | json_encode }} -->
<!-- raw_center type={{ _raw_center is iterable ? 'array' : 'scalar' }} json={{ _raw_center | json_encode }} -->
<!-- raw_end    type={{ _raw_end    is iterable ? 'array' : 'scalar' }} json={{ _raw_end    | json_encode }} -->
<!-- resolved   start={{ slot_start }} center={{ slot_center }} end={{ slot_end }} -->
<!-- HEADER DEBUG ▲ -->

{# ══════════════════════════════════════════════════════════════
   HEADER ELEMENT
   ══════════════════════════════════════════════════════════════ #}
<header
  class="store-header {{ header_is_transparent ? 'header-transparent' : '' }}"
  x-data="{ scrolled: false }"
  @scroll.window.throttle.50ms="scrolled = (window.scrollY > 60)"
  :class="{ 'header-scrolled': scrolled }"
>

  {# ── TOP BAR ────────────────────────────────────────────── #}
  {% if header_show_topbar %}
    <div class="top-navbar {{ topnav_is_dark ? 'topnav-is-dark' : '' }}">
      <div class="container flex justify-between items-center">
        <div class="flex flex-1 items-center gap-2">

          {% if important_links %}
            <salla-menu source="footer" topnav></salla-menu>
          {% endif %}

          {% if store.settings.is_multilingual or store.settings.currencies_enabled %}
            <div class="header-buttons">
              <button type="button" onclick="salla.event.dispatch('localization::open')" class="btn--rounded-gray basis-0">
                <span>{{ user.language.name }}</span>
                <span class="mx-1.5">|</span>
                <span>{{ currency.symbol }}</span>
              </button>
              <salla-localization-modal></salla-localization-modal>
            </div>
          {% endif %}

          {% if store.scope %}
            <button class="btn--rounded-gray" onclick="salla.event.dispatch('scopes::open', {'mode': 'default'})">
              <i class="sicon-location rtl:ml-1 ltr:mr-1"></i>
              {{ store.scope.name }}
            </button>
          {% endif %}
        </div>

        <salla-contacts is-header></salla-contacts>
      </div>
    </div>
  {% endif %}

  {# ── MAIN NAV ────────────────────────────────────────────── #}
  <div id="mainnav" class="main-nav-container" :class="scrolled ? 'header-nav--solid' : ''">
    <div class="inner bg-inherit w-full">
      <div class="container">
        <div class="header-matrix">

          {# Mobile hamburger — visible on small screens only #}
          <a class="header-mobile-toggle lg:hidden mburger mburger--collapse leading-none"
             href="#mobile-menu" aria-label="فتح القائمة">
            <i class="sicon-menu text-primary text-2xl"></i>
          </a>

          {# ── Slot START  (RTL=right, LTR=left) ─────────── #}
          <div class="header-slot header-slot--start">
            {% include 'components/header/_slot.twig' with (_slot_vars | merge({ slot: slot_start })) ignore missing %}
          </div>

          {# ── Slot CENTER ────────────────────────────────── #}
          <div class="header-slot header-slot--center">
            {% include 'components/header/_slot.twig' with (_slot_vars | merge({ slot: slot_center })) ignore missing %}
          </div>

          {# ── Slot END  (RTL=left, LTR=right) ───────────── #}
          <div class="header-slot header-slot--end">
            {% include 'components/header/_slot.twig' with (_slot_vars | merge({ slot: slot_end })) ignore missing %}
          </div>

        </div>
      </div>
    </div>
  </div>

</header>
